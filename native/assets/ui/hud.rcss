body {
    margin: 0dp;
    padding: 0dp;
    width: 100%;
    height: 100%;
    font-family: antonio;
    font-size: 14dp;
    color: #c8d8e8;
}

#hud {
    position: absolute;
    right: 10dp;
    top: 10dp;
    width: 280dp;
    text-align: right;
    background-color: #00000074;
    padding: 8dp;
    border-radius: 4dp;
}

#hud div {
    margin-bottom: 2dp;
    white-space: nowrap;
}
